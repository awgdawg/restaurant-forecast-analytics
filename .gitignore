# ── Secrets / credentials — NEVER commit (standing security rule) ──
.env
.env.*
!.env.example
*.pem
*.key
*.p12
credentials.json
token.json
secrets/
# dbt connection profile (can hold host/token) — commit profiles.yml.example instead
profiles.yml

# ── Raw data — keep out of git (repo hygiene; bulk data lives in the lakehouse) ──
data/
raw/
*.parquet
*.csv
# Tableau extracts / packaged workbooks embed data — keep only .twb
*.hyper
*.twbx
# allow committed dbt seeds (small / sample)
!seeds/**/*.csv

# ── Python ──
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.ipynb_checkpoints/

# ── dbt ──
target/
dbt_packages/
logs/
.user.yml

# ── OS / IDE ──
.DS_Store
Thumbs.db
.idea/
.vscode/

# ── Secrets / credentials — NEVER commit (standing security rule) ──
.env
.env.*
!.env.example
*.pem
*.key
*.p12
credentials.json
token.json
secrets/
profiles.yml            # dbt connection profile (may hold host/token) — commit profiles.yml.example instead

# ── Raw data — keep out of git (repo hygiene; bulk data lives in the lakehouse) ──
data/
raw/
*.parquet
*.hyper                 # Tableau extracts
*.twbx                  # packaged Tableau workbooks — keep .twb only
*.csv
!seeds/**/*.csv         # allow committed dbt seeds

# ── Python ──
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.ipynb_checkpoints/

# ── dbt ──
target/
dbt_packages/
logs/

# ── OS / IDE ──
.DS_Store
Thumbs.db
.idea/
.vscode/
